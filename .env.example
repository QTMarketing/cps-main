# QT Office Check Printing System — environment template
# Copy to .env.local and fill in your values. Do not commit secrets.

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/qt_office"

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET="change-me"
ENCRYPTION_KEY="change-me-64-hex-chars"

# QuickTrack Hub SSO — must match Hub SSO_SHARED_SECRET
SSO_SHARED_SECRET="change-me"

# Hub Assistant API — must match Hub CPS_APP_API_KEY
INTERNAL_ASSISTANT_API_KEY=

# Optional: map this email to CPS SUPER_ADMIN on Hub SSO
# SUPER_ADMIN_USERNAME="admin@quicktrackinc.com"

# Optional: auto-assign staff users to a store on first SSO
# CPS_SSO_DEFAULT_STORE_ID="1"

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
